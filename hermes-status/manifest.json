{
  "id": "hermes-status",
  "name": "Hermes Agent",
  "version": "1.4.0",
  "minNoctaliaVersion": "4.1.2",
  "author": "srk",
  "official": false,
  "license": "MIT",
  "repository": "https://github.com/Mel-SRK/noctalia-hermes",
  "description": "Traffic-light status indicator for Hermes Agent (CLI + Gateway). Shows online/busy/attention/degraded/offline states in the status bar with real-time hook-based updates.",
  "tags": ["Bar", "Panel", "AI", "Indicator", "Niri"],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "statusScript": "~/.config/noctalia/hermes-status-check",
      "pollInterval": 30,
      "signalFile": "~/.hermes/status_signal",
      "hideWhenIdle": false
    }
  }
}
