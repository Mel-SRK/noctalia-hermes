#!/usr/bin/env python3
"""hermes-status-hook — write Hermes lifecycle status for noctalia-hermes."""

from __future__ import annotations

import json
import os
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path

HOME = Path(os.environ.get("HOME", "~")).expanduser()
HERMES_DIR = Path(os.environ.get("HERMES_DIR", HOME / ".hermes")).expanduser()
SIGNAL_FILE = Path(os.environ.get("HERMES_STATUS_SIGNAL", HERMES_DIR / "status_signal")).expanduser()

EVENT_STATES = {
    # Active work / recent activity.
    "pre_llm_call": "busy",
    "post_llm_call": "busy",
    "pre_tool_call": "busy",
    "post_tool_call": "busy",
    "on_session_start": "busy",
    # Waiting for user interaction.
    "pre_approval_request": "attention",
    # User responded / lifecycle ended.
    "post_approval_response": "idle",
    "on_session_end": "idle",
    "on_session_finalize": "idle",
    "on_session_reset": "idle",
}


def main(argv: list[str]) -> int:
    event = argv[1] if len(argv) > 1 else "unknown"
    state = EVENT_STATES.get(event, "busy")

    payload = {
        "state": state,
        "event": event,
        "ts": datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds"),
    }

    SIGNAL_FILE.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{SIGNAL_FILE.name}.", suffix=".tmp", dir=str(SIGNAL_FILE.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            json.dump(payload, f, ensure_ascii=False, separators=(",", ":"))
            f.write("\n")
        os.replace(tmp_name, SIGNAL_FILE)
    except Exception:
        try:
            os.unlink(tmp_name)
        except OSError:
            pass
        raise

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
