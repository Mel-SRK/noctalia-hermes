#!/bin/bash
# hermes-status-hook — called by hermes shell hooks to write status signal
# Usage: hermes-status-hook <event> [extra_args...]
#
# Writes to ~/.hermes/status_signal with JSON:
#   {"state": "busy|attention|idle", "event": "pre_tool_call", "ts": "..."}

SIGNAL_FILE="${HOME}/.hermes/status_signal"
EVENT="$1"

case "$EVENT" in
  # Processing states → busy
  pre_llm_call|post_llm_call|pre_tool_call|post_tool_call|on_session_start)
    STATE="busy"
    ;;
  # Waiting for user → attention
  pre_approval_request)
    STATE="attention"
    ;;
  # User responded / session ended → idle
  post_approval_response|on_session_end|on_session_finalize|on_session_reset)
    STATE="idle"
    ;;
  *)
    STATE="busy"
    ;;
esac

# Write atomically via temp file
TMPFILE="${SIGNAL_FILE}.tmp.$$"
cat > "$TMPFILE" <<EOF
{"state":"${STATE}","event":"${EVENT}","ts":"$(date -Iseconds)"}
EOF
mv -f "$TMPFILE" "$SIGNAL_FILE"
