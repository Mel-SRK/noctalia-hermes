#!/usr/bin/env python3
"""hermes-status-check — emit Hermes Agent status as JSON for noctalia-hermes.

This script is intentionally self-contained and fast: it reads Hermes' status
files once, scans /proc once, then prints a single JSON object.
"""

from __future__ import annotations

import json
import os
import sqlite3
import time
from datetime import datetime
from pathlib import Path

HOME = Path(os.environ.get("HOME", "~")).expanduser()
HERMES_DIR = Path(os.environ.get("HERMES_DIR", HOME / ".hermes")).expanduser()
SIGNAL_FILE = Path(os.environ.get("HERMES_STATUS_SIGNAL", HERMES_DIR / "status_signal")).expanduser()
STATE_FILE = Path(os.environ.get("HERMES_GATEWAY_STATE", HERMES_DIR / "gateway_state.json")).expanduser()
ATTENTION_FILE = Path(os.environ.get("HERMES_ATTENTION_FILE", HERMES_DIR / "needs_attention")).expanduser()
STATE_DB = Path(os.environ.get("HERMES_STATE_DB", HERMES_DIR / "state.db")).expanduser()


def read_json(path: Path, fallback):
    try:
        with path.open("r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return fallback


def parse_epoch(value: str | None) -> float | None:
    if not value:
        return None
    try:
        # date -Iseconds writes e.g. 2026-05-29T14:50:51+08:00.
        return datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def scan_processes() -> tuple[bool, str, bool, str, str]:
    gateway_running = False
    gateway_pid = ""
    cli_active = False
    cli_pid = ""
    cli_session_id = ""

    proc = Path("/proc")
    for entry in proc.iterdir():
        if not entry.name.isdigit():
            continue
        pid = entry.name
        try:
            raw = (entry / "cmdline").read_bytes()
        except Exception:
            continue
        if not raw:
            continue
        parts = [p.decode("utf-8", "ignore") for p in raw.split(b"\0") if p]
        cmd = " ".join(parts)
        if "hermes_cli.main" not in cmd:
            continue

        is_gateway = "gateway" in parts and "run" in parts
        if is_gateway and not gateway_running:
            gateway_running = True
            gateway_pid = pid
        elif not is_gateway and not cli_active:
            cli_active = True
            cli_pid = pid
            for idx, part in enumerate(parts):
                if part == "--resume" and idx + 1 < len(parts):
                    cli_session_id = parts[idx + 1]
                    break
                if part.startswith("--resume="):
                    cli_session_id = part.split("=", 1)[1]
                    break

        if gateway_running and cli_active:
            break

    return gateway_running, gateway_pid, cli_active, cli_pid, cli_session_id


def safe_int(value) -> int:
    try:
        return int(value or 0)
    except Exception:
        return 0


def safe_float(value):
    try:
        if value is None:
            return None
        return float(value)
    except Exception:
        return None


def read_latest_usage(preferred_session_id: str = "") -> dict:
    """Read latest Hermes session token/cost snapshot from state.db."""
    empty = {
        "available": False,
        "session_id": "",
        "model": "",
        "provider": "",
        "input_tokens": 0,
        "output_tokens": 0,
        "cache_tokens": 0,
        "cache_read_tokens": 0,
        "cache_write_tokens": 0,
        "reasoning_tokens": 0,
        "total_tokens": 0,
        "api_call_count": 0,
        "estimated_cost_usd": None,
        "actual_cost_usd": None,
        "cost_status": "unknown",
        "cost_source": "",
    }
    if not STATE_DB.exists():
        return empty

    try:
        conn = sqlite3.connect(f"file:{STATE_DB}?mode=ro", uri=True, timeout=0.1)
        conn.row_factory = sqlite3.Row
        row = conn.execute(
            """
            SELECT id, source, model, billing_provider,
                   input_tokens, output_tokens, cache_read_tokens,
                   cache_write_tokens, reasoning_tokens, api_call_count,
                   estimated_cost_usd, actual_cost_usd, cost_status, cost_source,
                   started_at, ended_at,
                   (COALESCE(input_tokens, 0) + COALESCE(output_tokens, 0) +
                    COALESCE(cache_read_tokens, 0) + COALESCE(cache_write_tokens, 0) +
                    COALESCE(reasoning_tokens, 0)) AS token_total
            FROM sessions
            WHERE source = 'cli'
              AND (message_count > 0 OR token_total > 0 OR id = ?)
            ORDER BY
              CASE WHEN id = ? THEN 0
                   WHEN ended_at IS NULL AND token_total > 0 THEN 1
                   WHEN ended_at IS NULL THEN 2
                   WHEN token_total > 0 THEN 3
                   ELSE 4 END,
              COALESCE(ended_at, started_at) DESC
            LIMIT 1
            """,
            (preferred_session_id, preferred_session_id),
        ).fetchone()
        conn.close()
    except Exception:
        return empty

    if row is None:
        return empty

    input_tokens = safe_int(row["input_tokens"])
    output_tokens = safe_int(row["output_tokens"])
    cache_read_tokens = safe_int(row["cache_read_tokens"])
    cache_write_tokens = safe_int(row["cache_write_tokens"])
    reasoning_tokens = safe_int(row["reasoning_tokens"])
    cache_tokens = cache_read_tokens + cache_write_tokens
    total_tokens = input_tokens + output_tokens + cache_tokens + reasoning_tokens

    return {
        "available": True,
        "session_id": str(row["id"] or ""),
        "model": str(row["model"] or ""),
        "provider": str(row["billing_provider"] or ""),
        "input_tokens": input_tokens,
        "output_tokens": output_tokens,
        "cache_tokens": cache_tokens,
        "cache_read_tokens": cache_read_tokens,
        "cache_write_tokens": cache_write_tokens,
        "reasoning_tokens": reasoning_tokens,
        "total_tokens": total_tokens,
        "api_call_count": safe_int(row["api_call_count"]),
        "estimated_cost_usd": safe_float(row["estimated_cost_usd"]),
        "actual_cost_usd": safe_float(row["actual_cost_usd"]),
        "cost_status": str(row["cost_status"] or "unknown"),
        "cost_source": str(row["cost_source"] or ""),
    }


def main() -> int:
    gateway_running, gateway_pid, cli_active, cli_pid, cli_session_id = scan_processes()
    usage = read_latest_usage(cli_session_id)

    signal = read_json(SIGNAL_FILE, {})
    signal_state = str(signal.get("state") or "")
    signal_event = str(signal.get("event") or "")
    signal_ts = str(signal.get("ts") or "")

    signal_epoch = parse_epoch(signal_ts)
    signal_age = None
    if signal_epoch is not None:
        signal_age = max(0, int(time.time() - signal_epoch))

    # Safety net: if the signal says "busy" but the CLI process is gone and
    # the signal hasn't been refreshed in 60 s, the session likely crashed
    # without firing on_session_end.  Fall back to process-based status.
    STALE_BUSY_GRACE = 60
    if signal_state == "busy" and not cli_active and (signal_age is not None) and signal_age > STALE_BUSY_GRACE:
        signal_state = ""

    needs_attention = ATTENTION_FILE.exists()

    gateway_state = read_json(STATE_FILE, {})
    platforms = gateway_state.get("platforms", {}) if isinstance(gateway_state, dict) else {}
    if not isinstance(platforms, dict):
        platforms = {}
    status = "idle" if (gateway_running or cli_active) else "offline"

    if signal_state and signal_state != "idle":
        status = signal_state

    if needs_attention and status != "offline":
        status = "attention"

    if status == "idle":
        for value in platforms.values():
            if isinstance(value, dict) and value.get("state") != "connected":
                status = "degraded"
                break

    out = {
        "status": status,
        "gateway_running": gateway_running,
        "gateway_pid": gateway_pid,
        "cli_active": cli_active,
        "cli_pid": cli_pid,
        "cli_session_id": cli_session_id,
        "needs_attention": needs_attention,
        "signal_event": signal_event,
        "signal_ts": signal_ts,
        "signal_age": signal_age,
        "platforms": platforms,
        "usage": usage,
    }
    print(json.dumps(out, ensure_ascii=False, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
