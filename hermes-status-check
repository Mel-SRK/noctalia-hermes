#!/usr/bin/env python3
"""hermes-status-check — emit Hermes Agent status as JSON for noctalia-hermes.

This script is intentionally self-contained and fast: it reads Hermes' status
files once, scans /proc once, then prints a single JSON object.
"""

from __future__ import annotations

import json
import os
import time
from datetime import datetime
from pathlib import Path

HOME = Path(os.environ.get("HOME", "~")).expanduser()
HERMES_DIR = Path(os.environ.get("HERMES_DIR", HOME / ".hermes")).expanduser()
SIGNAL_FILE = Path(os.environ.get("HERMES_STATUS_SIGNAL", HERMES_DIR / "status_signal")).expanduser()
STATE_FILE = Path(os.environ.get("HERMES_GATEWAY_STATE", HERMES_DIR / "gateway_state.json")).expanduser()
ATTENTION_FILE = Path(os.environ.get("HERMES_ATTENTION_FILE", HERMES_DIR / "needs_attention")).expanduser()

BUSY_TTL_SECONDS = int(os.environ.get("HERMES_STATUS_BUSY_TTL", "30"))


def read_json(path: Path, fallback):
    try:
        with path.open("r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return fallback


def parse_epoch(value: str | None) -> float | None:
    if not value:
        return None
    try:
        # date -Iseconds writes e.g. 2026-05-29T14:50:51+08:00.
        return datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def scan_processes() -> tuple[bool, str, bool, str]:
    gateway_running = False
    gateway_pid = ""
    cli_active = False
    cli_pid = ""

    proc = Path("/proc")
    for entry in proc.iterdir():
        if not entry.name.isdigit():
            continue
        pid = entry.name
        try:
            raw = (entry / "cmdline").read_bytes()
        except Exception:
            continue
        if not raw:
            continue
        parts = [p.decode("utf-8", "ignore") for p in raw.split(b"\0") if p]
        cmd = " ".join(parts)
        if "hermes_cli.main" not in cmd:
            continue

        is_gateway = "gateway" in parts and "run" in parts
        if is_gateway and not gateway_running:
            gateway_running = True
            gateway_pid = pid
        elif not is_gateway and not cli_active:
            cli_active = True
            cli_pid = pid

        if gateway_running and cli_active:
            break

    return gateway_running, gateway_pid, cli_active, cli_pid


def main() -> int:
    gateway_running, gateway_pid, cli_active, cli_pid = scan_processes()

    signal = read_json(SIGNAL_FILE, {})
    signal_state = str(signal.get("state") or "")
    signal_event = str(signal.get("event") or "")
    signal_ts = str(signal.get("ts") or "")

    signal_epoch = parse_epoch(signal_ts)
    signal_age = None
    if signal_epoch is not None:
        signal_age = max(0, int(time.time() - signal_epoch))
        if signal_age > BUSY_TTL_SECONDS and signal_state == "busy":
            signal_state = "idle"

    needs_attention = ATTENTION_FILE.exists()

    gateway_state = read_json(STATE_FILE, {})
    platforms = gateway_state.get("platforms", {}) if isinstance(gateway_state, dict) else {}
    if not isinstance(platforms, dict):
        platforms = {}
    try:
        active_agents = int(gateway_state.get("active_agents", 0)) if isinstance(gateway_state, dict) else 0
    except Exception:
        active_agents = 0

    status = "idle" if (gateway_running or cli_active) else "offline"

    if signal_state and signal_state != "idle":
        status = signal_state

    if needs_attention and status != "offline":
        status = "attention"

    if status == "idle":
        for value in platforms.values():
            if isinstance(value, dict) and value.get("state") != "connected":
                status = "degraded"
                break

    out = {
        "status": status,
        "gateway_running": gateway_running,
        "gateway_pid": gateway_pid,
        "cli_active": cli_active,
        "cli_pid": cli_pid,
        "needs_attention": needs_attention,
        "active_agents": active_agents,
        "signal_event": signal_event,
        "signal_ts": signal_ts,
        "signal_age": signal_age,
        "platforms": platforms,
    }
    print(json.dumps(out, ensure_ascii=False, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
