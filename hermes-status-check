#!/bin/bash
# hermes-status-check — detect Hermes Agent status via hooks + process checks
# Outputs JSON with status, CLI state, gateway state, platform info
#
# Priority: hook signal > process detection > gateway state

SIGNAL_FILE="${HOME}/.hermes/status_signal"
STATE_FILE="${HOME}/.hermes/gateway_state.json"
ATTENTION_FILE="${HOME}/.hermes/needs_attention"

# 1. Check gateway process
GW_RUNNING=false
GW_PID=""
if pgrep -f "hermes_cli.*gateway run" > /dev/null 2>&1; then
  GW_RUNNING=true
  GW_PID=$(pgrep -f "hermes_cli.*gateway run" | head -1)
fi

# 2. Check CLI session
CLI_ACTIVE=false
CLI_PID=""
CLI_PID=$(ps -eo pid,tty,args --no-headers 2>/dev/null \
  | grep "hermes_cli.main" \
  | grep -v "gateway" \
  | grep -E "pts/" \
  | awk '{print $1}' | head -1)

if [ -n "$CLI_PID" ]; then
  CLI_ACTIVE=true
fi

# 3. Read hook signal file (primary source of truth)
SIGNAL_STATE=""
SIGNAL_EVENT=""
SIGNAL_TS=""
if [ -f "$SIGNAL_FILE" ]; then
  SIGNAL_STATE=$(python3 -c "
import json
try:
    d = json.load(open('$SIGNAL_FILE'))
    print(d.get('state', ''))
except: print('')
" 2>/dev/null)
  SIGNAL_EVENT=$(python3 -c "
import json
try:
    d = json.load(open('$SIGNAL_FILE'))
    print(d.get('event', ''))
except: print('')
" 2>/dev/null)
  SIGNAL_TS=$(python3 -c "
import json
try:
    d = json.load(open('$SIGNAL_FILE'))
    print(d.get('ts', ''))
except: print('')
" 2>/dev/null)

  # Check if signal is stale (> 30 seconds old) — treat as idle
  if [ -n "$SIGNAL_TS" ]; then
    NOW=$(date +%s)
    SIG_EPOCH=$(date -d "$SIGNAL_TS" +%s 2>/dev/null)
    if [ -n "$SIG_EPOCH" ]; then
      AGE=$((NOW - SIG_EPOCH))
      if [ "$AGE" -gt 30 ]; then
        SIGNAL_STATE="idle"
      fi
    fi
  fi
fi

# 4. Check attention flag
NEEDS_ATTENTION=false
[ -f "$ATTENTION_FILE" ] && NEEDS_ATTENTION=true

# 5. Read platform info from gateway_state.json
PLATFORMS="{}"
ACTIVE_AGENTS=0
if [ -f "$STATE_FILE" ]; then
  PLATFORMS=$(python3 -c "
import json
try:
    d = json.load(open('$STATE_FILE'))
    print(json.dumps(d.get('platforms', {})))
except: print('{}')
" 2>/dev/null)
  ACTIVE_AGENTS=$(python3 -c "
import json
try:
    d = json.load(open('$STATE_FILE'))
    print(d.get('active_agents', 0))
except: print(0)
" 2>/dev/null)
fi

# 6. Determine overall status (priority order)
STATUS="offline"
if $GW_RUNNING || $CLI_ACTIVE; then
  STATUS="idle"
fi

# Hook signal takes priority
if [ -n "$SIGNAL_STATE" ] && [ "$SIGNAL_STATE" != "idle" ]; then
  STATUS="$SIGNAL_STATE"
fi

# Attention flag overrides (but not offline)
if $NEEDS_ATTENTION && [ "$STATUS" != "offline" ]; then
  STATUS="attention"
fi

# Check platform degradation
if [ "$STATUS" = "idle" ]; then
  echo "$PLATFORMS" | python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
for k,v in d.items():
    if isinstance(v, dict) and v.get('state') != 'connected':
        sys.exit(0)
sys.exit(1)
" 2>/dev/null && STATUS="degraded"
fi

# 7. Output JSON
cat <<EOF
{
  "status": "$STATUS",
  "gateway_running": $GW_RUNNING,
  "gateway_pid": "$GW_PID",
  "cli_active": $CLI_ACTIVE,
  "cli_pid": "$CLI_PID",
  "needs_attention": $NEEDS_ATTENTION,
  "active_agents": $ACTIVE_AGENTS,
  "signal_event": "$SIGNAL_EVENT",
  "signal_ts": "$SIGNAL_TS",
  "platforms": $PLATFORMS
}
EOF
